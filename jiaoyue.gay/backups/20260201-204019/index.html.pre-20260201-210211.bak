    <script>
        (function () {
            // 使用?��??��??��??��??��?，強?�瀏覽?��?次都?�新讀?��?�?(清除快�?)
            var v = Date.now();
            var scripts = [
                'js/site-config.js', 'js/lang/zh.js', 'js/lang/en.js', 'js/lang/ja.js', 'js/lang/zh-Hans.js', 'js/lang/ko.js', 'js/fireworks.js',
                'js/works-modal.js', 'js/lang.js'
            ];
            scripts.forEach(function (src) {
                document.write('<script src="' + src + '?v=' + v + '"><\/script>');
            });
            // main.js 帶�? defer 屬性�??�?�獨?��?
            document.write('<script src="js/main.js?v=' + v + '" defer><\/script>');
        })();
    </script>


    <script>
        document.addEventListener('DOMContentLoaded', function () {
            // 自動更新年份
            const yearSpan = document.getElementById('current-year');
            if (yearSpan) yearSpan.textContent = new Date().getFullYear();

            const avatar = document.getElementById('about-avatar');
            if (!avatar) return;

            let clickCount = 0;
            let clickTimer = null;

            avatar.addEventListener('click', function () {
                // 僅在電腦版觸發 (寬度 >= 1024px)
                if (window.innerWidth < 1024) return;

                clickCount++;

                // 每次點擊重置計時器，若超過 0.5 秒未點擊則歸零
                if (clickTimer) clearTimeout(clickTimer);
                clickTimer = setTimeout(() => { clickCount = 0; }, 500);

                // 連續點擊 5 次觸發
                if (clickCount >= 5) {
                    clickCount = 0;

                    // 1. 設定轉場動畫 (旋轉 + 淡出)
                    avatar.style.transition = 'transform 1s ease-in-out, opacity 0.5s ease-in-out';
                    avatar.style.transform = 'rotate(360deg) scale(1.1)';
                    avatar.style.opacity = '0';

                    // 2. 0.5秒後 (淡出完成時) 更換圖片並淡入
                    setTimeout(() => {
                        if (avatar.src.includes('jiao_yue_profile_2.jpg')) {
                            avatar.src = 'images/jiao_yue_profile.jpg';
                        } else {
                            avatar.src = 'images/jiao_yue_profile_2.jpg';
                        }
                        avatar.style.opacity = '1';
                    }, 500);

                    // 3. 動畫結束後重置狀態
                    setTimeout(() => {
                        avatar.style.transition = 'none'; // 瞬間重置防止倒轉
                        avatar.style.transform = 'none';
                        setTimeout(() => { avatar.style.transition = ''; }, 50); // 恢復 CSS 定義
                    }, 1000);
                }
            });
        });
    </script>
